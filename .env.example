# Opencode Zen upstream
ZEN_BASE_URL=https://llm.chompe.rs
ZEN_AUTH_VERIFY_URL=https://llm.chompe.rs/v1/auth/verify
ZEN_API_HEADER=X-Zen-Api-Key

# Validation caching
AUTH_CACHE_TTL_SECONDS=300
AUTH_CACHE_MAX_SIZE=10000

# Proxy
UPSTREAM_TIMEOUT_SECONDS=60

# CORS (optional, comma-separated)
CORS_ORIGINS=

# Logging
LOG_LEVEL=info

# GitHub Enterprise auth
GITHUB_AUTH_ENABLED=true
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_ENTERPRISE_SLUG=
GITHUB_SESSION_TTL_SECONDS=28800
GITHUB_DEVICE_FLOW_ENABLED=true
GITHUB_DIRECT_TOKEN_ENABLED=true
# For OAuth App device flow, request scopes: read:org read:enterprise (GitHub Apps ignore this)
GITHUB_DEVICE_FLOW_SCOPES=read:org read:enterprise
SESSION_SECRET_KEY=
