# Opencode Zen upstream
ZEN_BASE_URL=https://llm.chompe.rs
ZEN_AUTH_VERIFY_URL=https://llm.chompe.rs/v1/auth/verify
ZEN_API_HEADER=X-Zen-Api-Key

# Validation caching
AUTH_CACHE_TTL_SECONDS=300
AUTH_CACHE_MAX_SIZE=10000

# Proxy
UPSTREAM_TIMEOUT_SECONDS=60

# CORS (optional, comma-separated)
CORS_ORIGINS=

# Logging
LOG_LEVEL=info
